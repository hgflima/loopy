{
  "productName": "Loopy",
  "version": "../../../package.json",
  "identifier": "com.hgflima.loopy.menubar",
  "build": {
    "beforeDevCommand": "vite",
    "beforeBuildCommand": "vite build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Loopy",
        "width": 1024,
        "height": 768,
        "visible": false
      },
      {
        "label": "popover",
        "title": "Loopy",
        "width": 320,
        "height": 180,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "about",
        "title": "Loopy",
        "width": 360,
        "height": 320,
        "visible": false,
        "resizable": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["bin/loopy"]
  }
}
