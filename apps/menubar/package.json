{
  "name": "@hgflima/loopy-menubar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build:sidecar": "mkdir -p src-tauri/bin && bun build --compile ../../src/index.ts --outfile src-tauri/bin/loopy-aarch64-apple-darwin && (codesign --remove-signature src-tauri/bin/loopy-aarch64-apple-darwin 2>/dev/null || true) && codesign -f -s - src-tauri/bin/loopy-aarch64-apple-darwin",
    "build": "npm run build:sidecar && tauri build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hgflima/loopy": "*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@xyflow/react": "^12",
    "react": "^18",
    "react-dom": "^18",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^29.1.1",
    "typescript": "^5",
    "vite": "^6"
  }
}
